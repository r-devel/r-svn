#: gpar.c:632
msgid "updateGContext must only be called after initGContext"
msgstr "updateGContext só deve ser chamado após initGContext"

#: grid.c:199
msgid "Turning clipping on or off within a (clipping) path is no honoured"
msgstr "Ativar ou desativar o recorte em um caminho (recorte) não está sendo respeitado"

#: grid.c:241
msgid "cannot clip to rotated viewport"
msgstr "Não é possível cortar sobre uma viewport rotacionada"

#: grid.c:456
msgid "Clipping paths within a (clipping) path are not honoured"
msgstr "O recorte dos caminhos dentro de um caminho (de recorte) não está sendo respeitado"

#: grid.c:475
msgid "Masks within a (clipping) path are not honoured"
msgstr "Máscaras dentro de um caminho (recorte) não estão sendo respeitadas"

#: grid.c:699 grid.c:877
#, c-format
msgid "Viewport '%s' was not found"
msgstr "A janela de visualização gráfica '%s' não foi encontrada"

#: grid.c:909 grid.c:914 grid.c:1035 grid.c:1040
#, fuzzy
msgid "cannot pop the top-level viewport ('grid' and 'graphics' output mixed?)"
msgstr "Não é possível mostrar a viewport de nível máximo (saidas gráficas e grid misturadas?)"

#: grid.c:1241
msgid "attempt to plot on null device"
msgstr "tentativa de fazer um gráfico no dispositivo nulo"

#: grid.c:1710
msgid "there is no layout defined"
msgstr "Não há layout definido"

#: grid.c:1932
msgid "polygon edge not found (zero-width or zero-height?)"
msgstr "Limite do polígono não encontrado (largura ou altura zero?)"

#: grid.c:1941
msgid "polygon edge not found"
msgstr "Limite do polígono não encontrado"

#: grid.c:2095
msgid "require at least two points to draw arrow"
msgstr "Pelo menos dois pontos são necessários para desenhar uma seta"

#: grid.c:2466
msgid "non-finite control point in Xspline"
msgstr "Ponto de controle não-finito em Xspline"

#: grid.c:3436
msgid "non-finite x or y in graphics path"
msgstr "valores não-finitos de x ou y no caminho do gráfico"

#: grid.c:3487
msgid "Empty raster"
msgstr "Raster vazio"

#: grid.c:4038 grid.c:4094
msgid "Coordinates for text pch not yet supported"
msgstr "Coordenadas para 'pch' de texto ainda não suportadas"

#: grid.c:4099
#, c-format
msgid "pch value '%d' is invalid in this locale"
msgstr "O valor pch '%d' é inválido nesta configuração de localidade"

#: grid.c:4920
#, c-format
msgid "unimplemented pch value '%d'"
msgstr "O valor '%d' de pch não está implementado"

#: grid.c:5079
msgid "invalid plotting symbol"
msgstr "simbolo para gráfico inválido"

#: grid.c:5198
msgid "unable to clip to rotated rectangle"
msgstr "Não é possível cortar sobre um retângulo rotacionado"

#: layout.c:600
msgid "invalid 'layout.pos.row'"
msgstr "'layout.pos.row' inválido"

#: layout.c:604
msgid "invalid 'layout.pos.col'"
msgstr "'layout.pos.col' inválido"

#: matrix.c:50
msgid "singular transformation matrix"
msgstr "matriz de transformação singular"

#: state.c:191
msgid "unable to store 'grid' state.  Too many devices open?"
msgstr "Não foi possível guardar o estado do 'grid'. Muitos dispositivos abertos?"

