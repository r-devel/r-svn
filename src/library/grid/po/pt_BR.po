msgstr "objeto não é uma unidade"

#: unit.c:1859
msgid "units can only be multiplied with numerics and integers"
msgstr "as unidades só podem ser multiplicadas por números numéricos ou inteiros"

#: util.c:216
msgid "Unable to calculate text width/height (using zero)"
msgstr "Não foi possível calcular a largura/altura do texto (usando zero)"

#: viewport.c:57
msgid "Mask is not logical value ('none' or 'inherit')"
msgstr "Mask não é um valor lógico ('none' ou 'inherit')"

#: viewport.c:331
msgid "non-finite location and/or size for viewport"
msgstr "Localização e/ou tamanhos não finitos para viewport"

