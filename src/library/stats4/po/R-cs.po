msgid "named list expected"
msgstr "očekáván pojmenovaný seznam"

msgid "some named values are not arguments to the supplied log-likelihood"
msgstr ""
"některé pojmenované hodnoty nejsou platnými argumenty pro dodanou "
"logaritmickou funkci věrohodnosti"

msgid "Mismatch in length of start values"
msgstr "Neshoda v délce počátečních hodnot"

msgid "fixed values violate constraints"
msgstr "fixní hodnoty porušují omezení"

msgid "start values do not satisfy constraints"
msgstr "počáteční hodnoty nevyhovují omezením"

msgid "profiling has found a better solution, so original fit had not converged"
msgstr ""
"profilování našlo lepší řešení, takže původní přizpůsobení nedosáhlo "
"konvergence"

msgid "levels truncated to positive values only"
msgstr "úrovně byly omezeny pouze na kladné hodnoty"

msgid "extra arguments discarded"
msgstr "přebytečné argumenty byly vyřazeny"
