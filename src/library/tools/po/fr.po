#: Rmd5.c:57 Rsha256.c:70
msgid "argument 'files' must be character"
msgstr "l'argument 'files' doit être une chaîne de caractères"

#: Rmd5.c:73
#, c-format
msgid "md5 failed on file '%ls'"
msgstr "md5 a échoué sur le fichier ‘%ls'"

