#: Rmd5.c:57 Rsha256.c:70
msgid "argument 'files' must be character"
msgstr "аргумент 'files' должен быть символьным"

#: Rmd5.c:73
#, c-format
msgid "md5 failed on file '%ls'"
msgstr "md5 на файле '%ls' не удался"

#: Rmd5.c:75
#, c-format
msgid "md5 failed on file '%s'"
msgstr "md5 на файле '%s' не удался"

#: Rsha256.c:86
#, fuzzy, c-format
msgid "sha256 failed on file '%ls'"
msgstr "md5 на файле '%ls' не удался"

#: Rsha256.c:88
#, fuzzy, c-format
msgid "sha256 failed on file '%s'"
msgstr "md5 на файле '%s' не удался"

#: getfmts.c:60
#, c-format
msgid "only %d arguments are allowed"
msgstr "разрешается только %d аргументов"

#: getfmts.c:65
msgid "'fmt' is not a character vector"
msgstr "'fmt' не текстовый вектор"

#: getfmts.c:68
msgid "'fmt' must be length 1"
msgstr "'fmt' должен быть единичной длины"

#: getfmts.c:74
#, c-format
msgid "'fmt' length exceeds maximal format length %d"
msgstr "длина 'fmt' превышает максимальную длину формата %d"

#: getfmts.c:95
#, c-format
msgid "unrecognised format specification '%s'"
msgstr "нераспознанное описание формата '%s'"

#: getfmts.c:135
msgid "at most one asterisk '*' is supported in each conversion specification"
msgstr "самое большее одна звездочка '*' поддерживается в каждом описании преобразования"

#: gramLatex.c:2856 gramRd.c:3967
#, c-format
msgid "unable to allocate buffer for long string at line %d"
msgstr "не могу разместить буфер для длинной подстроки на строке %d"

#: gramLatex.c:3167 gramRd.c:4521 gramRd.c:4527
#, c-format
msgid "invalid '%s' value"
msgstr "неправильное значение '%s'"

#: gramRd.c:2576 gramRd.c:2579
#, c-format
msgid "bad markup (extra space?) at %s:%d:%d"
msgstr "плохая разметка (лишний пробел?) на %s:%d:%d"

#: gramRd.c:3112
#, c-format
msgid "Macro '%s' previously defined."
msgstr "Макро '%s' уже определен."

#: gramRd.c:3122
#, c-format
msgid "At most 4 arguments are allowed for user defined macros."
msgstr "Максимум 4 аргумента разрешены для пользовательских макросов."

#: gramRd.c:3164
#, c-format
msgid "No macro definition for '%s'."
msgstr "Нет определения макроса для '%s'."

#: gramRd.c:3227
#, c-format
msgid "Not enough arguments passed to user macro '%s'"
msgstr "Недостаточно аргументов для пользовательских макроса '%s'"

#: gramRd.c:3367 gramRd.c:3371
#, c-format
msgid "newline within quoted string at %s:%d"
msgstr "новая строка внутри закавыченной подстроки на %s:%d"

#: gramRd.c:3390
#, c-format
msgid "unable to allocate buffer for long macro at line %d"
msgstr "не могу разместить буфер для длинного макро на строке %d"

#: gramRd.c:3420
msgid "macros nested too deeply: infinite recursion?"
msgstr "макро вложены слишком глубоко: бесконечная рекурсия?"

#: gramRd.c:3829
#, c-format
msgid "Unable to find macro %s"
msgstr "Не могу найти макро %s"

#: gramRd.c:4028
#, c-format
msgid "Unexpected end of input (in %c quoted string opened at %s:%d:%d)"
msgstr "Неожиданный конец ввода (в %c закавыченная строка открыта на %s:%d:%d)"

#: gramRd.c:4534
msgid "cannot open the connection"
msgstr "не могу открыть соединение"

#: gramRd.c:4541
msgid "cannot read from this connection"
msgstr "не могу прочесть из этого соединения"

#: gramRd.c:4549
msgid "invalid Rd file"
msgstr "неправильный Rd-файл"

#: gramRd.c:4569
msgid "'deparseRd' only supports deparsing character elements"
msgstr "'deparseRd' поддерживает только deparsing-символы"

#: gramRd.c:4572
msgid "bad state"
msgstr "плохое состояние"

#: gramRd.c:4585
#, c-format
msgid "bad text mode %d in 'deparseRd'"
msgstr "плохой текстовый режим %d в 'deparseRd'"

#: http.c:31
msgid "invalid bind address specification"
msgstr "неправильное описание адреса привязки"

#: http.c:36
#, c-format
msgid "Invalid port number %d: should be in 0:65535, typically above 1024"
msgstr "Неправильный номер порта %d: должен входить в 0:65535, обычно выше 1024"

#: http.c:60
msgid "allocation error in remove_dot_segments"
msgstr ""

#: http.c:150 pdscan.c:121
msgid "non-character argument"
msgstr "не-символьный аргумент"

#: install.c:95
msgid "path too long"
msgstr "футь к файлу слишком длинный"

#: install.c:120 install.c:139 install.c:141
#, c-format
msgid "invalid '%s' argument"
msgstr "неправильный аргумент '%s'"

#: install.c:170
msgid "write error during file append"
msgstr "ошибка записи в процессе добавления файла"

#: pdscan.c:74
msgid "too many items"
msgstr "слишком много пунктов"

#: signals.c:42
msgid "pskill() is not supported on this platform"
msgstr "pskill() на этой платформе не поддерживается"

#: signals.c:140
msgid "psnice() is not supported on this platform"
msgstr "psnice()  на этой платформе не поддерживается"

#: text.c:69
msgid "invalid argument type"
msgstr "неправильный тип аргумента"

#: text.c:227 text.c:249
msgid "out of memory"
msgstr "не хватает памяти"
